---
// src/components/SEO.astro
export interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'article' | 'profile' | 'book';
  locale?: string;
  schema?: 'person' | 'organization' | 'website' | 'article' | 'breadcrumb' | 'faq';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  tags?: string[];
  jobTitle?: string;
}

const {
  title,
  description,
  image = '/social.jpg',
  canonical,
  type = 'website',
  locale = 'es_AR',
  schema = 'website',
  publishedTime,
  modifiedTime,
  author = 'Pablo Marchetti Orayen',
  tags = [],
  jobTitle = 'IT Infrastructure Specialist',
} = Astro.props;

// ===== OBTENER URL BASE DESDE CONFIGURACIÓN =====
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://villars.solarispkn.com.ar';
const fullUrl = new URL(canonical ?? '/', siteUrl).toString();
const fullImage = image.startsWith('http') ? image : new URL(image, siteUrl).toString();

// ===== JSON-LD SEGÚN SCHEMA =====
let jsonLd = {};
switch (schema) {
  case 'person':
    jsonLd = {
      '@context': 'https://schema.org',
      '@type': 'Person',
      'name': author,
      'url': siteUrl,
      'image': fullImage,
      'jobTitle': jobTitle,
      'sameAs': [
        'https://github.com/SolarisPKN',
        'https://linkedin.com/in/solarispkn',
        'https://youtube.com/@SolarisPKN',
        'https://discord.gg/A9DW7S7Kaz',
        'https://facebook.com/solarispkn',
        'https://kick.com/Solarispkn',
        'https://twitch.tv/solarispkn',
        'https://instagram.com/solarispkn',
        'https://tiktok.com/@solarispkn',
        'https://x.com/SolarisPKN',
        'https://linktr.ee/SolarisPKN',
        'https://orcid.org/0009-0008-3003-1736'
      ]
    };
    break;
  case 'website':
    jsonLd = {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      'name': 'Villars Informa',
      'url': siteUrl,
      'description': description,
      'potentialAction': {
        '@type': 'SearchAction',
        'target': `${siteUrl}/search?q={search_term_string}`,
        'query-input': 'required name=search_term_string'
      }
    };
    break;
  case 'article':
    jsonLd = {
      '@context': 'https://schema.org',
      '@type': 'Article',
      'headline': title,
      'description': description,
      'author': { '@type': 'Person', 'name': author },
      'datePublished': publishedTime,
      'dateModified': modifiedTime || publishedTime,
      'image': fullImage
    };
    break;
  default:
    jsonLd = {};
}

// ===== LOCALE PARA OPEN GRAPH =====
const ogLocale = locale;
// CORREGIDO: solo español, sin operador ternario incorrecto
const ogLocaleAlternate = 'es_AR';
---

<!-- ===== META BÁSICAS ===== -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
<meta name="generator" content="Astro" />
<meta name="author" content={author} />
<meta name="theme-color" content="#0a0a0a" />
<meta name="color-scheme" content="dark" />
<meta name="language" content={ogLocale.split('_')[0]} />
<meta name="referrer" content="strict-origin-when-cross-origin" />
<meta name="format-detection" content="telephone=no" />

<!-- ===== VERIFICACIÓN (placeholder) ===== -->
<meta name="google-site-verification" content="" />
<meta name="msvalidate.01" content="" />
<meta name="yandex-verification" content="" />

<title>{title} | Villars Informa</title>
<meta name="description" content={description} />
<link rel="canonical" href={fullUrl} />

<!-- ===== OPEN GRAPH ===== -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:image:alt" content={title} />
<meta property="og:url" content={fullUrl} />
<meta property="og:type" content={type} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:locale:alternate" content={ogLocaleAlternate} />
<meta property="og:site_name" content="Villars Informa" />

<!-- ===== TWITTER CARD ===== -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImage} />
<meta name="twitter:image:alt" content={title} />

<!-- ===== ICONOS ===== -->
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/manifest.webmanifest" />

<!-- ===== JSON-LD ===== -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />