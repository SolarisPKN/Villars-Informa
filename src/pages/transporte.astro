---
import Layout from '../layouts/Layout.astro';
import t from '../locales/transporte.json';
---

<Layout title={t.titulo}>
  <div class="transporte-container">
    <h1>{t.titulo}</h1>
    <p>{t.descripcion}</p>

    <div class="transport-controls">
      <select id="tipoTransporte" class="transport-select">
        <option value="colectivo">🚌 Colectivo</option>
        <option value="tren">🚆 Tren</option>
      </select>
    </div>

    <div id="horarios-container">
      <!-- Colectivo -->
      <div id="colectivo-horarios" class="horario-block">
        <h2>Horarios de Colectivo</h2>
        <div id="proximo-colectivo" class="proximo">
          <p>Próximo colectivo: <span id="proximo-tiempo">Calculando...</span></p>
        </div>
        <div id="tabla-colectivo">
          <p>Cargando horarios...</p>
        </div>
      </div>
      <!-- Tren -->
      <div id="tren-horarios" class="horario-block" style="display:none;">
        <h2>Horarios de Tren</h2>
        <p>Próximo tren: <span id="proximo-tren">Calculando...</span></p>
        <div id="tabla-tren">
          <ul>
            <li>06:30 - Villars - Buenos Aires</li>
            <li>08:15 - Villars - Buenos Aires</li>
            <li>10:00 - Villars - Buenos Aires</li>
            <li>12:45 - Villars - Buenos Aires</li>
            <li>15:30 - Villars - Buenos Aires</li>
            <li>18:20 - Villars - Buenos Aires</li>
            <li>21:10 - Villars - Buenos Aires</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .transporte-container { max-width: 900px; margin: 0 auto; padding: 2rem 1rem; }
  .transport-select { padding: 0.5rem 1rem; border-radius: 30px; background: var(--glass); color: var(--text-light); border: 1px solid rgba(255,255,255,0.15); }
  .horario-block { margin-top: 2rem; background: var(--glass); padding: 1.5rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.08); }
  .proximo { background: rgba(0,255,204,0.1); padding: 0.5rem 1rem; border-radius: 30px; display: inline-block; margin-bottom: 1rem; }
  .horario-block table { width: 100%; border-collapse: collapse; }
  .horario-block th, .horario-block td { padding: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.05); text-align: left; }
  .horario-block ul { list-style: none; padding: 0; }
  .horario-block li { padding: 0.3rem 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const select = document.getElementById('tipoTransporte');
    const colectivoBlock = document.getElementById('colectivo-horarios');
    const trenBlock = document.getElementById('tren-horarios');

    select.addEventListener('change', () => {
      if (select.value === 'colectivo') {
        colectivoBlock.style.display = 'block';
        trenBlock.style.display = 'none';
      } else {
        colectivoBlock.style.display = 'none';
        trenBlock.style.display = 'block';
      }
    });

    // ===== HORARIOS DE COLECTIVO (ejemplo) =====
    function cargarHorariosColectivo() {
      const tabla = document.getElementById('tabla-colectivo');
      tabla.innerHTML = `
        <table>
          <tr><th>Salida</th><th>Destino</th></tr>
          <tr><td>06:00</td><td>Villars - Centro</td></tr>
          <tr><td>07:30</td><td>Villars - Centro</td></tr>
          <tr><td>09:00</td><td>Villars - Centro</td></tr>
          <tr><td>10:30</td><td>Villars - Centro</td></tr>
          <tr><td>12:00</td><td>Villars - Centro</td></tr>
          <tr><td>14:00</td><td>Villars - Centro</td></tr>
          <tr><td>16:00</td><td>Villars - Centro</td></tr>
          <tr><td>18:00</td><td>Villars - Centro</td></tr>
          <tr><td>20:00</td><td>Villars - Centro</td></tr>
        </table>
      `;
      const horarios = ['06:00','07:30','09:00','10:30','12:00','14:00','16:00','18:00','20:00'];
      calcularProximo('proximo-tiempo', horarios);
    }

    // ===== CÁLCULO DE PRÓXIMO SERVICIO =====
    function calcularProximo(elementId, horarios) {
      const ahora = new Date();
      const minutosActuales = ahora.getHours() * 60 + ahora.getMinutes();
      let proximo = null;
      let menorDiferencia = Infinity;
      for (let h of horarios) {
        const [hh, mm] = h.split(':').map(Number);
        const minutos = hh * 60 + mm;
        let diff = minutos - minutosActuales;
        if (diff < 0) diff += 1440;
        if (diff < menorDiferencia) {
          menorDiferencia = diff;
          proximo = h;
        }
      }
      const element = document.getElementById(elementId);
      if (element) {
        if (proximo) {
          const horas = Math.floor(menorDiferencia / 60);
          const minutos = menorDiferencia % 60;
          element.textContent = `${proximo} (en ${horas}h ${minutos}min)`;
        } else {
          element.textContent = 'No hay más servicios hoy';
        }
      }
    }

    // ===== HORARIOS DE TREN =====
    const trenHorarios = ['06:30','08:15','10:00','12:45','15:30','18:20','21:10'];
    calcularProximo('proximo-tren', trenHorarios);

    // Inicializar
    cargarHorariosColectivo();
  });
</script>