---
import Layout from '../layouts/Layout.astro';
import t from '../locales/404.json';
---

<Layout title={t.titulo}>
  <div style="display: flex; flex-direction: column; align-items: center; justify-content: flex-start; min-height: 100vh; padding: 2rem; padding-top: 25vh; background-color: #0a0a0a; background-image: url('/images/background-404.webp'); background-size: contain; background-position: center; background-repeat: no-repeat; position: relative;">
    <!-- Overlay sutil -->
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.25); z-index: 1;"></div>
    <!-- Contenido (sin recuadro) -->
    <div style="position: relative; z-index: 2; text-align: center; max-width: 600px; width: 90%;">
      <h2 style="font-size: 2.2rem; color: var(--text-light); margin: 0 0 1.5rem 0; font-weight: 300; text-shadow: 0 0 20px rgba(0,0,0,0.5);">{t.titulo}</h2>
      <a href="/" style="display: inline-block; padding: 0.75rem 2rem; text-decoration: none; color: var(--border-cyan); border: 1px solid var(--border-cyan); border-radius: 30px; transition: all 0.3s ease; background: rgba(0, 0, 0, 0.4); backdrop-filter: blur(4px); font-weight: 500;">
        {t.boton} 🏠
      </a>
    </div>
    <style>
      a:hover {
        background: var(--border-cyan);
        color: #0a0a0a;
        box-shadow: 0 0 20px rgba(0,255,204,0.3);
      }
    </style>
  </div>
</Layout>