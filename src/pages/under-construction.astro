---
// src/pages/[lang]/under-construction.astro
export async function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params;
import Layout from '../../layouts/Layout.astro';
const t = await import(`../../locales/${lang}/under-construction.json`);
---

<Layout title={t.titulo} lang={lang}>
  <div style="position: relative; min-height: 100vh; display: flex; align-items: center; justify-content: center; background-image: url('/images/background-construction.webp'); background-size: cover; background-position: center; background-repeat: no-repeat;">
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.6); z-index: 1;"></div>
    <div class="glass" style="position: relative; z-index: 2; max-width: 600px; width: 90%; padding: 2rem; text-align: center;">
      <h1 style="font-size: 3rem; color: var(--accent-pink);">🚧</h1>
      <h2>{t.titulo}</h2>
      <p>{t.descripcion}</p>
      <p style="font-family: monospace; font-size: 0.8rem;">{t.mensajeTecnico}</p>
      <a href={`/${lang}`} class="glass" style="display: inline-block; margin-top: 1rem; padding: 0.75rem 1.5rem; text-decoration: none; color: var(--border-cyan); border: 1px solid var(--border-cyan); border-radius: 30px;">
        {t.boton} 🏠
      </a>
    </div>
  </div>
</Layout>