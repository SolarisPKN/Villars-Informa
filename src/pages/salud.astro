---
import Layout from '../layouts/Layout.astro';
import homeData from '../locales/home.json';
import { Content } from '../locales/home-descripcion.mdx';

// Lista de imágenes (pon las rutas reales de tus imágenes en /public/images/home/)
// Si no tienes imágenes, el carrusel no se mostrará (o puedes mostrar un placeholder)
const imagenes = [
  // '/images/home/foto1.webp',
  // '/images/home/foto2.jpg',
  // '/images/home/foto3.png',
];

// Si hay imágenes, usa la primera como principal; si no, usa un placeholder
const imagenPrincipal = imagenes.length ? imagenes[0] : '/images/placeholder-pueblo.jpg';
---

<Layout title="Villars Informa">
  <section class="hero-pueblo">
    <div class="hero-content">
      <h1 class="frase-grande">{homeData.frasePueblo}</h1>
      <div class="historia">
        <Content />
      </div>
    </div>
  </section>

  <!-- CARRUSEL (solo si hay imágenes) -->
  {imagenes.length > 0 && (
    <section class="carrusel-pueblo">
      <div class="marco-madera">
        <div class="imagen-principal">
          <img id="imagenGrande" src={imagenPrincipal} alt="Villars" />
        </div>
      </div>
      <div class="carrusel-miniaturas" id="carouselWrapper">
        <div class="track" id="carouselTrack">
          {imagenes.map(url => (
            <div class="item-miniatura" data-src={url}>
              <img src={url} alt="Miniatura" loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- BOTÓN AL DIRECTORIO -->
  <div style="text-align: center; margin-top: 2rem;">
    <a href="/directorio" class="boton-pueblo">📋 Ver comercios del pueblo</a>
  </div>
</Layout>

<style>
  /* ===== HERO ===== */
  .hero-pueblo {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    background: radial-gradient(ellipse at center, rgba(212, 163, 115, 0.1) 0%, transparent 70%);
  }
  .hero-content {
    max-width: 900px;
    width: 100%;
  }
  .frase-grande {
    font-size: clamp(1.8rem, 6.3vw, 3.4rem);
    font-family: 'Georgia', 'Times New Roman', serif;
    color: var(--accent-mustard);
    text-shadow: 0 4px 20px rgba(233, 196, 106, 0.3);
    margin-bottom: 2rem;
    text-align: center;
    letter-spacing: -0.02em;
  }

  /* ===== ESTILOS PARA EL CONTENIDO MDX ===== */
  .historia {
    max-width: 800px;
    margin: 0 auto;
    background: rgba(0, 0, 0, 0.3);
    padding: 2rem 2.5rem;
    border-radius: 16px;
    border-left: 4px solid var(--accent-mustard);
    color: var(--text-light);
    font-size: 1.1rem;
    line-height: 1.8;
    text-align: left;
  }

  /* Párrafos */
  .historia p {
    margin-bottom: 1.2rem;
  }

  /* Encabezados */
  .historia h1 {
    font-size: 2rem;
    font-family: 'Georgia', 'Times New Roman', serif;
    color: var(--accent-mustard);
    margin: 2rem 0 1rem;
    border-bottom: 1px solid rgba(212, 163, 115, 0.2);
    padding-bottom: 0.5rem;
  }
  .historia h2 {
    font-size: 1.6rem;
    font-family: 'Georgia', 'Times New Roman', serif;
    color: var(--accent-mustard);
    margin: 1.8rem 0 0.8rem;
  }
  .historia h3 {
    font-size: 1.3rem;
    font-family: 'Georgia', 'Times New Roman', serif;
    color: var(--accent-terracotta);
    margin: 1.5rem 0 0.5rem;
  }

  /* Blockquotes (citas) */
  .historia blockquote {
    border-left: 3px solid var(--accent-mustard);
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: #D4C5A0;
    background: rgba(212, 163, 115, 0.05);
    border-radius: 4px;
    padding: 1rem 1.5rem;
  }
  .historia blockquote p {
    margin-bottom: 0;
  }

  /* Listas */
  .historia ul, .historia ol {
    margin: 1rem 0 1.5rem 1.5rem;
  }
  .historia li {
    margin-bottom: 0.5rem;
  }

  /* Enlaces dentro del contenido (si los hay) */
  .historia a {
    color: var(--accent-mustard);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }
  .historia a:hover {
    color: var(--border-amber);
  }

  /* Línea horizontal */
  .historia hr {
    border: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--accent-mustard), transparent);
    margin: 2rem 0;
  }

  /* ===== CARRUSEL CON MARCO ===== */
  .carrusel-pueblo {
    max-width: 1000px;
    margin: 3rem auto;
    padding: 0 1rem;
  }
  .marco-madera {
    background: #2C1E16;
    padding: 12px;
    border-radius: 20px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.6), inset 0 0 0 1px #5A3D2B;
    margin-bottom: 1rem;
  }
  .imagen-principal {
    width: 100%;
    height: 450px;
    overflow: hidden;
    border-radius: 12px;
    background: #1A1410;
  }
  .imagen-principal img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.4s ease;
  }

  .carrusel-miniaturas {
    overflow: hidden;
    cursor: grab;
    user-select: none;
    padding: 0.5rem 0;
  }
  .track {
    display: flex;
    gap: 0.75rem;
    width: max-content;
    transition: transform 0.05s linear;
  }
  .item-miniatura {
    flex: 0 0 130px;
    height: 85px;
    border-radius: 12px;
    overflow: hidden;
    border: 3px solid transparent;
    transition: border-color 0.2s;
    cursor: pointer;
    background: #2C1E16;
  }
  .item-miniatura img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .item-miniatura.activa {
    border-color: var(--accent-mustard);
    box-shadow: 0 0 16px rgba(233, 196, 106, 0.4);
  }

  /* ===== BOTÓN ===== */
  .boton-pueblo {
    display: inline-block;
    padding: 0.8rem 2.5rem;
    background: var(--accent-mustard);
    color: #1A1410;
    border-radius: 40px;
    font-weight: 600;
    font-size: 1.1rem;
    text-decoration: none;
    transition: all 0.3s;
    box-shadow: 0 4px 12px rgba(233, 196, 106, 0.3);
  }
  .boton-pueblo:hover {
    background: #D4A373;
    transform: scale(1.02);
    box-shadow: 0 6px 20px rgba(212, 163, 115, 0.5);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .imagen-principal { height: 300px; }
    .item-miniatura { flex: 0 0 90px; height: 60px; }
    .historia { padding: 1.2rem; font-size: 1rem; }
    .historia h1 { font-size: 1.6rem; }
    .historia h2 { font-size: 1.3rem; }
    .frase-grande { font-size: 2.2rem; }
  }
  @media (max-width: 480px) {
    .historia { padding: 1rem; }
    .historia blockquote { padding: 0.8rem; }
  }
</style>

<!-- Script del carrusel (solo si hay imágenes) -->
{imagenes.length > 0 && (
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const track = document.getElementById('carouselTrack');
      const wrapper = document.getElementById('carouselWrapper');
      const imagenGrande = document.getElementById('imagenGrande');
      const items = Array.from(track.querySelectorAll('.item-miniatura'));
      if (!track || !wrapper || !imagenGrande || items.length === 0) return;

      items.forEach(item => {
        const clone = item.cloneNode(true);
        track.appendChild(clone);
      });

      let currentTranslateX = 0, speed = 0.3, isPaused = false, isDragging = false;
      let startX = 0, prevTranslateX = 0, animationId = null;

      function setMainImage(src) {
        imagenGrande.style.opacity = '0';
        setTimeout(() => {
          imagenGrande.src = src;
          imagenGrande.style.opacity = '1';
        }, 150);
        items.forEach(el => el.classList.remove('activa'));
        const target = items.find(el => el.dataset.src === src);
        if (target) target.classList.add('activa');
      }

      track.addEventListener('click', (e) => {
        const item = e.target.closest('.item-miniatura');
        if (item) { const src = item.dataset.src; if (src) setMainImage(src); }
      });

      function animate() {
        if (isPaused || isDragging) { animationId = requestAnimationFrame(animate); return; }
        currentTranslateX -= speed;
        const maxTranslate = -(track.scrollWidth / 2);
        if (currentTranslateX <= maxTranslate) currentTranslateX = 0;
        track.style.transform = `translateX(${currentTranslateX}px)`;
        animationId = requestAnimationFrame(animate);
      }

      wrapper.addEventListener('mousedown', (e) => {
        isDragging = true; isPaused = true;
        startX = e.clientX; prevTranslateX = currentTranslateX;
        track.style.transition = 'none';
        if (animationId) cancelAnimationFrame(animationId);
      });
      document.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        const diff = e.clientX - startX;
        let newX = prevTranslateX + diff;
        const maxX = 0, minX = -(track.scrollWidth / 2);
        if (newX > maxX) newX = maxX;
        if (newX < minX) newX = minX;
        currentTranslateX = newX;
        track.style.transform = `translateX(${currentTranslateX}px)`;
      });
      document.addEventListener('mouseup', () => {
        if (isDragging) {
          isDragging = false;
          setTimeout(() => { isPaused = false; if (!animationId) animate(); }, 1000);
        }
      });

      wrapper.addEventListener('touchstart', (e) => {
        isDragging = true; isPaused = true;
        startX = e.touches[0].clientX; prevTranslateX = currentTranslateX;
        track.style.transition = 'none';
        if (animationId) cancelAnimationFrame(animationId);
      }, { passive: true });
      document.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        const diff = e.touches[0].clientX - startX;
        let newX = prevTranslateX + diff;
        const maxX = 0, minX = -(track.scrollWidth / 2);
        if (newX > maxX) newX = maxX;
        if (newX < minX) newX = minX;
        currentTranslateX = newX;
        track.style.transform = `translateX(${currentTranslateX}px)`;
      }, { passive: true });
      document.addEventListener('touchend', () => {
        if (isDragging) {
          isDragging = false;
          setTimeout(() => { isPaused = false; if (!animationId) animate(); }, 1000);
        }
      }, { passive: true });

      wrapper.addEventListener('mouseenter', () => { isPaused = true; });
      wrapper.addEventListener('mouseleave', () => {
        isPaused = false;
        if (!animationId) animate();
      });

      if (items.length > 0) items[0].classList.add('activa');
      animate();

      window.addEventListener('beforeunload', () => {
        if (animationId) cancelAnimationFrame(animationId);
      });
    });
  </script>
)}